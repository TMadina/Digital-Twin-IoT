import pandas as pd
import folium

df=pd.read_csv('sensors.csv')

class Sensor:
    def __init__(self, lat, lon, risk, temperature,pressure):
      self.lat= lat
      self.lon= lon
      self.risk= risk
      self.temperature= temperature
      self.pressure = pressure

    def is_dangerous(self):
      return self.temperature > 50 or self.risk == 'High'

    def get_color(self):
      if self.is_dangerous():
        return 'red'
      elif self.risk == 'Medium':
        return 'orange'
      else:
        return 'green'

    def add_to_map(self, map_obj):
      folium.CircleMarker(
          location = [self.lat, self.lon],
          radius = 6,
          color = self.get_color(),
          fill = True,
          fill_opacity = 0.7,
          popup = f"Temp: {self.temperature}, Risk: {self.risk}, Pressure: {self.pressure}"
      ).add_to(map_obj)

Sensors = []

for _, row in df.iterrows():
  Sensors.append(
      Sensor(
          row['lat'],
          row['lon'],
          row['risk'],
          row['temperature'],
          row['pressure']
      )
  )
m= folium.Map(location = [52,76], zoom_start = 6)

for s in Sensors:
  s.add_to_map(m)

m.save("map.html")


class Segment:
  def __init__(self, sensor1, sensor2):
    self.sensor1 = sensor1
    self.sensor2 = sensor2

  def pressure_drop(self):
    return self.sensor1.pressure - self.sensor2.pressure

  def has_leak(self, threshold = 10):
    return self.pressure_drop()> threshold

  def get_coordinates(self):
    return[
        [self.sensor1.lat, self.sensor1.lon],
        [self.sensor2.lat, self.sensor2.lon]
    ]

  def get_midpoint(self):
    lat = (self.sensor1.lat + self.sensor2.lat)/2
    lon = (self.sensor1.lon + self.sensor2.lon)/2
    return [lat, lon]

  def add_to_map(self, map_obj):
    import folium
    color = 'red' if self.has_leak() else 'blue'

    folium.PolyLine(
        locations= self.get_coordinates(),
        color= color,
        weight = 4
    ).add_to(map_obj)

  def get_severity(self, drop):
    if drop > 30:
      return 'Critical'
    elif drop > 20:
      return 'High'
    else:
      return 'Low'

  def generate_alert(self):
    drop= self.pressure_drop()
    if drop>15:
      return Alert(
          type = 'pressure drop',
          severity = self.get_severity(drop),
          location = self.get_midpoint()
      )
    else:
      return None



for i in range(len(Sensors)-1):
  seg= Segment(Sensors[i], Sensors[i+1])
  Segments.append(seg)
for seg in Segments:
    seg.add_to_map(m)
m.save("map.html")
